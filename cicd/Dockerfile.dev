# =============================================================================
# Call-Center-AI 开发环境 Dockerfile
# =============================================================================
# 用途：本地开发，支持热重载
# 构建：docker build -f cicd/Dockerfile.dev -t call-center-ai:dev .
# =============================================================================

# 使用 uv 作为包管理器的 Python 3.13 镜像
FROM ghcr.io/astral-sh/uv:python3.13-bookworm-slim

# 设置工作目录
WORKDIR /app

# 安装系统依赖
# - build-essential: 编译 Python C 扩展
# - curl: 健康检查
# - git: 版本信息（可选）
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# 复制依赖定义文件
COPY pyproject.toml uv.lock ./

# 安装 Python 依赖（核心 + 开发）
ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --extra dev

# 复制应用代码
COPY . .

# 设置 Python 路径
ENV PATH="/app/.venv/bin:${PATH}"
ENV PYTHONPATH="/app:${PYTHONPATH}"

# 允许应用获取版本信息
ARG VERSION=0.0.0-dev
ENV VERSION=${VERSION}

# 暴露端口
EXPOSE 8080

# 开发模式启动命令（支持热重载）
# --reload: 代码变更时自动重启
# --log-level info: 显示详细日志
CMD ["granian", \
     "--interface", "asgi", \
     "--host", "0.0.0.0", \
     "--port", "8080", \
     "--log-level", "info", \
     "--reload", \
     "--workers", "1", \
     "--workers-kill-timeout", "60", \
     "app.main:api"]

